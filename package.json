{
  "name": "vernix",
  "version": "0.1.0",
  "private": true,
  "license": "Elastic-2.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "pnpm db:push && next build",
    "build:app": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:network": "vitest run -c vitest.network.config.ts",
    "test:all": "vitest run && vitest run -c vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "validate": "pnpm test && pnpm format && pnpm lint --fix && pnpm typecheck && pnpm knip"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.73",
