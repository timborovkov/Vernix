# Database
DATABASE_URL=postgresql://vernix:vernix_dev@localhost:5432/vernix

# Qdrant
QDRANT_URL=http://localhost:6380

# OpenAI
OPENAI_API_KEY=sk-...

# Auth
AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# App URL (for webhook callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn.ingest.de.sentry.io
NEXT_PUBLIC_SENTRY_ENABLED=false
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=sntrys_auth_token

# Meeting Bot Provider (recall | mock)
MEETING_BOT_PROVIDER=recall

# Recall.ai (if using recall provider)
RECALL_API_KEY=your-recall-api-key
RECALL_API_URL=https://eu-central-1.recall.ai/api/v1
RECALL_WEBHOOK_SECRET=your-recall-webhook-secret

# OAuth SSO (optional — leave blank to disable)
# Google Login: Create at https://console.cloud.google.com/apis/credentials
# Callback URL: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub Login: Create at https://github.com/settings/developers
# Callback URL: {AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend (email provider — optional, emails disabled without API key)
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=
# Webhook signing secret for inbound email forwarding
RESEND_WEBHOOK_SECRET=
# Comma-separated list of emails to forward all @vernix.app inbound emails to
EMAIL_FORWARD_TO=tim@example.com

# Polar (billing — optional, billing features disabled without it)
POLAR_ACCESS_TOKEN=polar_pat_...
POLAR_WEBHOOK_SECRET=
NEXT_PUBLIC_POLAR_PRODUCT_ID_PRO_MONTHLY=
NEXT_PUBLIC_POLAR_PRODUCT_ID_PRO_ANNUAL=
# Set to "sandbox" for testing, "production" for live
POLAR_SERVER=sandbox

# Cron jobs (for scheduled tasks like trial warning emails)
CRON_SECRET=your-cron-secret-here
RECORDING_RETENTION_DAYS=90  # Optional, default 90

# S3 / Minio (for knowledge base file storage)
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=vernix
S3_SECRET_KEY=vernix_dev
S3_BUCKET=vernix-knowledge
S3_REGION=us-east-1

# GitHub MCP: Separate OAuth app for MCP integration
# Callback URL: {NEXT_PUBLIC_APP_URL}/api/mcp/oauth/callback
GITHUB_MCP_CLIENT_ID=
GITHUB_MCP_CLIENT_SECRET=